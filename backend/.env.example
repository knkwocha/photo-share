# ============================================================
# PhotoShare Backend — Environment Variables
# Copy this file to .env and fill in your Azure values
# ============================================================

# Server
PORT=3000
NODE_ENV=production

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Azure PostgreSQL (Flexible Server)
DB_HOST=your-server.postgres.database.azure.com
DB_PORT=5432
DB_NAME=photoshare
DB_USER=psadmin
DB_PASSWORD=your_db_password
DB_SSL=true

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=yourphotosharestorage
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key
AZURE_STORAGE_CONTAINER_NAME=photos

# Azure Cognitive Services (Computer Vision)
AZURE_VISION_ENDPOINT=https://your-vision.cognitiveservices.azure.com/
AZURE_VISION_KEY=your_computer_vision_key

# Azure Cache for Redis
REDIS_HOST=your-redis.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=your_redis_key
REDIS_TLS=true

# CORS — set to your frontend URL (Azure Static Web Apps URL)
CORS_ORIGIN=https://your-frontend.azurestaticapps.net

# Creator registration secret (prevents open creator sign-up)
CREATOR_REGISTRATION_SECRET=change_this_secret_key
